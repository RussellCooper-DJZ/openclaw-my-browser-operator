{
  "manifest_version": 3,
  "name": "OpenClaw MY Browser Operator",
  "version": "1.0.0",
  "description": "Connect OpenClaw AI Agent to your real local browser. Reuse your logins, sessions, and local IP — no sandbox, no re-authentication.",
  "author": "RussellCooper-DJZ",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon":  { "16": "icons/icon16.png", "48": "icons/icon48.png" },
    "default_title": "OpenClaw MY Browser Operator"
  },

  "side_panel": {
    "default_path": "panel/panel.html"
  },

  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/relay.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sidePanel",
    "notifications",
    "debugger",
    "cookies"
  ],

  "host_permissions": ["<all_urls>"]
}
